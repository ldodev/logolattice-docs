{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Logo Lattice",
  "description": "Documentation for Logo Lattice - the browser-based grid logo editor",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/api-reference/studio-logo-api/introduction"
    },
    {
      "source": "/index",
      "destination": "/api-reference/studio-logo-api/introduction"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Studio Logo API",
            "openapi": "api-reference/studio-logo-api/openapi.json",
            "pages": [
              "api-reference/studio-logo-api/introduction",
              "api-reference/studio-logo-api/authentication",
              "api-reference/studio-logo-api/quickstart",
              "api-reference/studio-logo-api/generate-logo",
              "api-reference/studio-logo-api/get-usage",
              "api-reference/studio-logo-api/errors",
              "api-reference/studio-logo-api/quotas",
              "api-reference/studio-logo-api/reference-images",
              "api-reference/studio-logo-api/best-practices",
              "api-reference/studio-logo-api/changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Logo Lattice",
          "href": "https://logolattice.com",
          "icon": "grid"
        },
        {
          "anchor": "Studio",
          "href": "https://logolattice.com/studio/api-keys",
          "icon": "key"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@logolattice.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Logo Lattice",
      "href": "https://logolattice.com"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/logolattice"
    }
  }
}